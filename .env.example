# Copiar a .env.local (nunca commitar .env.local; usar SIEMPRE valores de un proyecto
# Supabase de desarrollo/staging, jamás las credenciales de producción en local)

NEXT_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Solo para scripts de servidor/migraciones administrativas — nunca expuesta al cliente
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Proveedores de IA (arquitectura multi-modelo, ver get-ai-provider.ts).
# AI_PROVIDER decide cuál se usa: 'gemini' (por defecto, capa gratuita) o 'anthropic'.
AI_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
